{
  "name": "codegraph",
  "version": "0.1.0",
  "description": "Generate a local AI coding usage heatmap from Codex and Claude Code session data.",
  "type": "module",
  "packageManager": "bun@1.3.9",
  "bin": {
    "codegraph": "./src/cli.ts"
  },
  "scripts": {
    "dev": "bun --watch ./src/cli.ts",
    "start": "bun ./src/cli.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "check": "bun test"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "codex",
    "claude",
    "cli",
    "heatmap",
    "usage",
    "svg"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3"
  }
}
