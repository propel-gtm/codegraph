{
  "name": "@propel-code/codegraph",
  "version": "0.2.3",
  "description": "Generate a local AI coding usage heatmap from Codex and Claude Code session data.",
  "type": "module",
  "packageManager": "bun@1.3.9",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "bin": {
    "codegraph": "dist/bin.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "bun --watch ./src/cli.ts",
    "start": "bun ./src/cli.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "check": "bun test && bun run typecheck",
    "prepack": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "codex",
    "claude",
    "cli",
    "heatmap",
    "usage",
    "svg",
    "png"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/propel-gtm/codegraph.git"
  },
  "homepage": "https://github.com/propel-gtm/codegraph#readme",
  "bugs": {
    "url": "https://github.com/propel-gtm/codegraph/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2"
  }
}
